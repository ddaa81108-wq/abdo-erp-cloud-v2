rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // المنطوم٩ ERP — ورتيقة والصحديس رئيسة
    match /erp_system/main_state {
      // القرابة: أي مستدد مس٬ل دخوله
      allow read: if request.auth != null;
      // الكتاةاة: أي مستدد مسجل دخوله (الإسحم بالصلحاحيات تيي اجامل التظوفاف)
      allow write: if request.auth != null;
    }
    // منع الؘرصل لأي مستنقات آخرع
    match /{document=**} {
      allow read, write: if false;
    }
  }
}