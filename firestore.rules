rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // وثيقة الحالة الرئيسية لنظام ABDO ERP V2
    // ==========================================
    match /erp_system/main_state {
      
      // القراءة: أي مستخدم مسجل دخوله
      allow read: if request.auth != null;
      
      // الكتابة: المستخدمين المسجلين فقط
      // ⚠️ تنبيه أمني: يُنصح بإضافة Firebase Custom Claims
      //    لتقييد الكتابة على الأدمن فقط على مستوى القاعدة
      //    حاليًا التحكم بالصلاحيات يتم من داخل التطبيق
      allow write: if request.auth != null;
    }
    
    // منع الوصول لأي مستندات أخرى
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
